var MIG_EXPECT = {"di_lam_total": 4442, "congno_total": 260391600.0, "daily_rows": 1032, "demand_rows": 208, "skipDaily": 16, "skipDemand": 9, "funnel_bad": 11, "queue": ["Feiliks", "Quocquang", "Thuận Phước", "Thuận Phước 16"]};

function mig_objs_(arr, keys) {
  return arr.map(function (r) { var o = {}; for (var i = 0; i < keys.length; i++) o[keys[i]] = r[i]; return o; });
}
function mig_set_(arr, k, v) { return arr.map(function (o) { o[k] = v; return o; }); }

function runMigration() {
  ormAllow_();
  var ui; try { ui = SpreadsheetApp.getUi(); } catch (e) {}
  // 1) Xóa dữ liệu cũ (giữ Branch, CategoryValue, Settings, AgingThreshold, CareFrequency, Users)
  ['Staff','Customer','Project','ProjectSpecialist','Workshop','WorkshopAlias','ProjectAlias',
   'NameQueue','WeeklyDemand','DailyReport','WeeklyKPI','Policy','CareTask','CareLog',
   'Receivable','ReceivableLog','KpiRecomputeLog','AuditLog'].forEach(function(k){ dbClear(k); });

  // 2) Ghi theo LÔ (setValues) — nhanh, tránh timeout
  dbBulkInsert('Staff', mig_set_(mig_objs_(MIG.staff, ['name','full_name','branch','vai_tro','trang_thai']), 'is_active', true));
  dbBulkInsert('Customer', mig_set_(mig_objs_(MIG.customer, ['name','customer_name','branch','phan_loai','quan_ly_phu_trach']), 'is_active', true));
  dbBulkInsert('Project', mig_set_(mig_objs_(MIG.project, ['name','project_name','customer','branch','phan_loai','quan_ly_phu_trach','trang_thai']), 'is_active', true));
  dbBulkInsert('ProjectSpecialist', mig_objs_(MIG.specialist, ['parent','specialist','specialist_name','vai_tro_trong_du_an']));
  dbBulkInsert('Workshop', mig_set_(mig_objs_(MIG.workshop, ['name','workshop_name','project','customer','branch','parent_workshop','is_group']), 'status', 'Active'));
  dbBulkInsert('ProjectAlias', mig_objs_(MIG.projectAlias, ['alias','alias_normalized','project']));
  dbBulkInsert('WorkshopAlias', mig_objs_(MIG.workshopAlias, ['alias','alias_normalized','workshop']));
  dbBulkInsert('NameQueue', mig_objs_(MIG.nameQueue, ['raw_text','raw_normalized','context','status']));
  dbBulkInsert('WeeklyDemand', mig_objs_(MIG.demand, ['name','ma','tuan','chi_nhanh','du_an','xuong','quan_ly','chuyen_vien','nhu_cau_kh_tuan','kpi_giao']));
  dbBulkInsert('DailyReport', mig_set_(mig_objs_(MIG.daily, ['name','ma','ngay','tuan','du_an','xuong','chi_nhanh','phuong_thuc','chuyen_vien','dang_ky','phong_van','do_pv','di_lam']), 'docstatus', 1));
  dbBulkInsert('Policy', mig_objs_(MIG.policy, ['name','ma','khach_hang','xuong','du_an','dang_tuyen','don_gia','don_vi','yeu_cau','luong_co_ban','phu_cap','co_ktx']));
  dbBulkInsert('CareTask', mig_objs_(MIG.care, ['name','ma','khach_hang','chi_nhanh','quan_ly','hoat_dong','tan_suat','ngay_kh','noi_dung','workflow_state']).map(function(o){ o.mocneo_cadence = o.ngay_kh; return o; }));
  dbBulkInsert('Receivable', mig_objs_(MIG.receivable, ['name','ma','chi_nhanh','khach_hang','du_an','quan_ly_phu_trach','ky_cong_no','so_tien','ngay_den_han','da_thu','ghi_chu']));
  MIG.receivable.forEach(function(r){ applyReceivableDerive(r[0]); rcvInitState_(r[0]); rcvSyncMoneyState(r[0]); });

  // 3) Roll-up KPI (đọc/ghi 1 lần)
  var rc = recomputeAllWeeksBulk();

  // 4) Đối soát
  var rec = reconcileMigration_();
  var msg = 'Migration xong (bulk). Tuần KPI=' + rc.weeks + ', dòng=' + rc.rows + '. ' + rec;
  if (ui) ui.alert(msg); else Logger.log(msg);
  return msg;
}

function reconcileMigration_() {
  var diLam = 0; dbAll('WeeklyKPI').forEach(function(o){ diLam += num_(o.di_lam); });
  var congno = 0; dbAll('Receivable').forEach(function(o){ congno += num_(o.so_tien); });
  var okDi = (diLam === MIG_EXPECT.di_lam_total);
  var okCn = (congno === MIG_EXPECT.congno_total);
  return 'Σ Đi làm: ' + diLam + '/' + MIG_EXPECT.di_lam_total + (okDi?' ✓':' ✗') +
         ' | Σ Công nợ: ' + congno + '/' + MIG_EXPECT.congno_total + (okCn?' ✓':' ✗') +
         ' | Daily=' + dbAll('DailyReport').length + '/' + MIG_EXPECT.daily_rows +
         ' | bỏ qua(queue): Daily=' + MIG_EXPECT.skipDaily + ' Demand=' + MIG_EXPECT.skipDemand +
         ' | funnel lỗi nguồn=' + MIG_EXPECT.funnel_bad;
}
